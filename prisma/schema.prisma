generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id                  String             @id @default(cuid())
  email               String             @unique
  passwordHash        String             @db.Text
  name                String?
  role                String             @default("editor")
  roleId              String?
  roleRef             Role?              @relation(fields: [roleId], references: [id])
  avatar              String?            @db.Text
  isActive            Boolean            @default(true)
  lastLoginAt         DateTime?
  emailSignature      String?            @db.MediumText
  signatureHtml       String?            @db.MediumText
  signatureTemplateId String?
  signatureTemplate   SignatureTemplate? @relation(fields: [signatureTemplateId], references: [id])
  scanLandingPageId   String?
  scanLandingPage     LandingPageConfig? @relation(fields: [scanLandingPageId], references: [id])
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([signatureTemplateId])
  @@index([roleId])
  @@index([scanLandingPageId])
}

model Role {
  id          String      @id @default(cuid())
  name        String      @unique
  label       String
  permissions String      @default("{}") @db.Text
  isSystem    Boolean     @default(false)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  users       AdminUser[]
}

model SignatureTemplate {
  id             String      @id @default(cuid())
  name           String
  logoUrl        String?     @db.MediumText
  bannerUrl      String?     @db.MediumText
  showInstagram  Boolean     @default(true)
  showFacebook   Boolean     @default(true)
  showWeb        Boolean     @default(true)
  instagramUrl   String?     @db.Text
  facebookUrl    String?     @db.Text
  webLinkUrl     String?     @db.Text
  websiteUrl     String?     @db.Text
  website        String?     @db.Text
  disclaimerLang String      @default("it") @db.Text
  footerIt       String?     @db.Text
  footerEn       String?     @db.Text
  ecoText        String?     @db.Text
  style          String      @default("geb")
  showLinkedin   Boolean     @default(true)
  linkedinUrl    String?
  showPinterest  Boolean     @default(true)
  pinterestUrl   String?
  isDefault      Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  users          AdminUser[]
}

model Designer {
  id             String                @id @default(cuid())
  name           String
  slug           String                @unique
  bio            String?               @db.Text
  country        String?               @db.Text
  imageUrl       String?               @db.Text
  website        String?               @db.Text
  isActive       Boolean               @default(true)
  isFeatured     Boolean               @default(false)
  sortOrder      Int                   @default(0)
  seoTitle       String?               @db.Text
  seoDescription String?               @db.Text
  seoKeywords    String?               @db.Text
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  products       Product[]
  translations   DesignerTranslation[]

  @@index([slug])
}

model Product {
  id                  String               @id @default(cuid())
  name                String
  slug                String               @unique
  designerId          String?
  designerName        String               @db.Text
  category            String
  subcategory         String?
  description         String?              @db.Text
  materials           String?              @db.Text
  dimensions          String?              @db.Text
  dimensionBlockId    String?              @db.Text
  dimensionValues     String?              @db.Text
  coverImage          String?              @db.Text
  heroImage           String?              @db.Text
  sideImage           String?              @db.Text
  galleryImages       String?              @db.Text
  galleryOrientations String?              @db.Text
  variants            String?              @db.Text
  dimensionImage      String?              @db.Text
  techSheetUrl        String?              @db.Text
  model2dUrl          String?              @db.Text
  model3dUrl          String?              @db.Text
  pconUrl             String?              @db.Text
  pconMoc             String?              @db.VarChar(32)
  pconBan             String?              @db.VarChar(64)
  pconSid             String?              @db.VarChar(64)
  pconOvc             String?              @db.Text
  year                Int?
  imageUrl            String               @default("") @db.Text
  isFeatured          Boolean              @default(false)
  isNew               Boolean              @default(false)
  isActive            Boolean              @default(true)
  sortOrder           Int                  @default(0)
  seoTitle            String?              @db.Text
  seoDescription      String?              @db.Text
  seoKeywords         String?              @db.Text
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  designer            Designer?            @relation(fields: [designerId], references: [id])
  projects            ProjectProduct[]
  awards              AwardProduct[]
  translations        ProductTranslation[]
  extraDimensions     ProductDimension[]
  storeProduct        StoreProduct?

  @@index([category])
  @@index([subcategory])
  @@index([slug])
  @@index([designerId])
}

model ProductDimension {
  id        String  @id @default(cuid())
  productId String
  name      String? @db.Text
  blockId   String? @db.Text
  values    String? @db.Text
  freeText  String? @db.Text
  image     String? @db.Text
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Project {
  id               String               @id @default(cuid())
  name             String
  slug             String               @unique
  type             String
  country          String
  city             String?              @db.Text
  year             Int?
  architect        String?              @db.Text
  description      String?              @db.Text
  shortDescription String?              @db.Text
  imageUrl         String               @db.Text
  coverImage       String?              @db.Text
  heroImage        String?              @db.Text
  sideImage        String?              @db.Text
  galleryUrls      String?              @db.Text
  isActive         Boolean              @default(true)
  sortOrder        Int                  @default(0)
  seoTitle         String?              @db.Text
  seoDescription   String?              @db.Text
  seoKeywords      String?              @db.Text
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  products         ProjectProduct[]
  translations     ProjectTranslation[]

  @@index([type])
  @@index([country])
  @@index([slug])
}

model ProjectProduct {
  id        String  @id @default(cuid())
  projectId String
  productId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([projectId, productId])
}

model Campaign {
  id             String                @id @default(cuid())
  name           String
  slug           String                @unique
  type           String                @default("")
  subtitle       String?               @db.Text
  description    String?               @db.Text
  imageUrl       String                @db.Text
  galleryUrls    String?               @db.Text
  videoUrl       String?               @db.Text
  blocks         String?               @db.Text
  year           Int?
  isActive       Boolean               @default(true)
  sortOrder      Int                   @default(0)
  seoTitle       String?               @db.Text
  seoDescription String?               @db.Text
  seoKeywords    String?               @db.Text
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  translations   CampaignTranslation[]

  @@index([slug])
  @@index([type])
}

model NewsArticle {
  id             String                   @id @default(cuid())
  title          String
  slug           String                   @unique
  category       String                   @default("")
  subtitle       String?                  @db.Text
  excerpt        String?                  @db.Text
  content        String?                  @db.Text
  imageUrl       String                   @db.Text
  galleryUrls    String?                  @db.Text
  blocks         String?                  @db.Text
  tags           String?                  @db.Text
  source         String?                  @db.Text
  sourceUrl      String?                  @db.Text
  publishedAt    DateTime?
  isActive       Boolean                  @default(true)
  sortOrder      Int                      @default(0)
  seoTitle       String?                  @db.Text
  seoDescription String?                  @db.Text
  seoKeywords    String?                  @db.Text
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  translations   NewsArticleTranslation[]

  @@index([slug])
  @@index([category])
}

model Award {
  id              String             @id @default(cuid())
  name            String
  productName     String?            @db.Text
  productSlug     String?            @db.Text
  productCategory String?            @db.Text
  year            Int
  organization    String?            @db.Text
  description     String?            @db.Text
  imageUrl        String?            @db.Text
  url             String?            @db.Text
  isActive        Boolean            @default(true)
  seoTitle        String?            @db.Text
  seoDescription  String?            @db.Text
  seoKeywords     String?            @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  products        AwardProduct[]
  translations    AwardTranslation[]

  @@index([year])
}

model AwardProduct {
  id        String  @id @default(cuid())
  awardId   String
  productId String
  award     Award   @relation(fields: [awardId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([awardId, productId])
}

model HeroSlide {
  id               String                 @id @default(cuid())
  title            String
  subtitle         String?                @db.Text
  ctaText          String?                @db.Text
  ctaLink          String?                @db.Text
  imageUrl         String                 @db.Text
  coverImage       String?                @db.Text
  videoUrl         String?                @db.Text
  position         String                 @default("center") @db.Text
  verticalPosition String                 @default("center") @db.Text
  imagePosition    String                 @default("center center") @db.VarChar(32)
  textColor        String                 @default("white") @db.VarChar(16)
  darkOverlay      Boolean                @default(false)
  overlayOpacity   Int                    @default(60)
  page             String                 @default("homepage")
  isActive         Boolean                @default(true)
  sortOrder        Int                    @default(0)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  translations     HeroSlideTranslation[]

  @@index([page])
}

model Language {
  id         String   @id @default(cuid())
  code       String   @unique
  name       String
  nativeName String?  @db.Text
  flag       String?  @db.Text
  urlPrefix  String?  @unique @db.VarChar(16)
  isDefault  Boolean  @default(false)
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  productTranslations     ProductTranslation[]
  designerTranslations    DesignerTranslation[]
  projectTranslations     ProjectTranslation[]
  campaignTranslations    CampaignTranslation[]
  newsTranslations        NewsArticleTranslation[]
  catalogTranslations     CatalogTranslation[]
  heroSlideTranslations   HeroSlideTranslation[]
  awardTranslations       AwardTranslation[]
  uiTranslations          UiTranslationOverride[]
  categoryTranslations    ContentCategoryTranslation[]
  typologyTranslations    ContentTypologyTranslation[]
  subcategoryTranslations ContentSubcategoryTranslation[]

  storeCategoryTranslations       StoreCategoryTranslation[]
  storeAttributeValueTranslations StoreAttributeValueTranslation[]
  storeProductTranslations        StoreProductTranslation[]
  storeProductVariantTranslations StoreProductVariantTranslation[]
}

model ContentCategoryTranslation {
  id           String          @id @default(cuid())
  categoryId   String
  languageCode String          @db.VarChar(16)
  label        String
  status       String          @default("draft") @db.VarChar(16)
  isPublished  Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  category     ContentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  language     Language        @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  @@unique([categoryId, languageCode])
  @@index([languageCode])
}

model ContentTypologyTranslation {
  id           String          @id @default(cuid())
  typologyId   String
  languageCode String          @db.VarChar(16)
  label        String
  status       String          @default("draft") @db.VarChar(16)
  isPublished  Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  typology     ContentTypology @relation(fields: [typologyId], references: [id], onDelete: Cascade)
  language     Language        @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  @@unique([typologyId, languageCode])
  @@index([languageCode])
}

model ContentSubcategoryTranslation {
  id            String             @id @default(cuid())
  subcategoryId String
  languageCode  String             @db.VarChar(16)
  label         String
  status        String             @default("draft") @db.VarChar(16)
  isPublished   Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  subcategory   ContentSubcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  language      Language           @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  @@unique([subcategoryId, languageCode])
  @@index([languageCode])
}

model ProductTranslation {
  id             String   @id @default(cuid())
  productId      String
  languageCode   String   @db.VarChar(16)
  name           String
  slug           String   @db.VarChar(191)
  description    String?  @db.Text
  materials      String?  @db.Text
  dimensions     String?  @db.Text
  variants       String?  @db.Text
  seoTitle       String?  @db.Text
  seoDescription String?  @db.Text
  seoKeywords    String?  @db.Text
  status         String   @default("draft") @db.VarChar(16)
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  language       Language @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  @@unique([productId, languageCode])
  @@unique([languageCode, slug])
  @@index([languageCode])
}

model DesignerTranslation {
  id             String   @id @default(cuid())
  designerId     String
  languageCode   String   @db.VarChar(16)
  name           String
  slug           String   @db.VarChar(191)
  bio            String?  @db.Text
  country        String?  @db.Text
  seoTitle       String?  @db.Text
  seoDescription String?  @db.Text
  seoKeywords    String?  @db.Text
  status         String   @default("draft") @db.VarChar(16)
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  designer       Designer @relation(fields: [designerId], references: [id], onDelete: Cascade)
  language       Language @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  @@unique([designerId, languageCode])
  @@unique([languageCode, slug])
  @@index([languageCode])
}

model ProjectTranslation {
  id               String   @id @default(cuid())
  projectId        String
  languageCode     String   @db.VarChar(16)
  name             String
  slug             String   @db.VarChar(191)
  city             String?  @db.Text
  architect        String?  @db.Text
  description      String?  @db.Text
  shortDescription String?  @db.Text
  seoTitle         String?  @db.Text
  seoDescription   String?  @db.Text
  seoKeywords      String?  @db.Text
  status           String   @default("draft") @db.VarChar(16)
  isPublished      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  language         Language @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  @@unique([projectId, languageCode])
  @@unique([languageCode, slug])
  @@index([languageCode])
}

model CampaignTranslation {
  id             String   @id @default(cuid())
  campaignId     String
  languageCode   String   @db.VarChar(16)
  name           String
  slug           String   @db.VarChar(191)
  subtitle       String?  @db.Text
  description    String?  @db.Text
  blocks         String?  @db.Text
  seoTitle       String?  @db.Text
  seoDescription String?  @db.Text
  seoKeywords    String?  @db.Text
  status         String   @default("draft") @db.VarChar(16)
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  campaign       Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  language       Language @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  @@unique([campaignId, languageCode])
  @@unique([languageCode, slug])
  @@index([languageCode])
}

model NewsArticleTranslation {
  id             String      @id @default(cuid())
  newsArticleId  String
  languageCode   String      @db.VarChar(16)
  title          String
  slug           String      @db.VarChar(191)
  subtitle       String?     @db.Text
  excerpt        String?     @db.Text
  content        String?     @db.Text
  blocks         String?     @db.Text
  seoTitle       String?     @db.Text
  seoDescription String?     @db.Text
  seoKeywords    String?     @db.Text
  status         String      @default("draft") @db.VarChar(16)
  isPublished    Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  newsArticle    NewsArticle @relation(fields: [newsArticleId], references: [id], onDelete: Cascade)
  language       Language    @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  @@unique([newsArticleId, languageCode])
  @@unique([languageCode, slug])
  @@index([languageCode])
}

model CatalogTranslation {
  id           String   @id @default(cuid())
  catalogId    String
  languageCode String   @db.VarChar(16)
  name         String
  slug         String   @db.VarChar(191)
  pretitle     String?  @db.Text
  title        String?  @db.Text
  description  String?  @db.Text
  linkText     String?  @db.Text
  status       String   @default("draft") @db.VarChar(16)
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  catalog      Catalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  language     Language @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  @@unique([catalogId, languageCode])
  @@unique([languageCode, slug])
  @@index([languageCode])
}

model HeroSlideTranslation {
  id           String    @id @default(cuid())
  heroSlideId  String
  languageCode String    @db.VarChar(16)
  title        String
  subtitle     String?   @db.Text
  ctaText      String?   @db.Text
  ctaLink      String?   @db.Text
  status       String    @default("draft") @db.VarChar(16)
  isPublished  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  heroSlide    HeroSlide @relation(fields: [heroSlideId], references: [id], onDelete: Cascade)
  language     Language  @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  @@unique([heroSlideId, languageCode])
  @@index([languageCode])
}

model AwardTranslation {
  id             String   @id @default(cuid())
  awardId        String
  languageCode   String   @db.VarChar(16)
  name           String
  description    String?  @db.Text
  seoTitle       String?  @db.Text
  seoDescription String?  @db.Text
  seoKeywords    String?  @db.Text
  status         String   @default("draft") @db.VarChar(16)
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  award          Award    @relation(fields: [awardId], references: [id], onDelete: Cascade)
  language       Language @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  @@unique([awardId, languageCode])
  @@index([languageCode])
}

model Redirect {
  id         String    @id @default(cuid())
  fromPath   String    @unique @db.VarChar(500)
  toPath     String    @db.VarChar(500)
  statusCode Int       @default(301)
  enabled    Boolean   @default(true)
  hits       Int       @default(0)
  lastHitAt  DateTime?
  note       String?   @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([enabled])
}

model UiTranslationOverride {
  id           String   @id @default(cuid())
  key          String   @db.VarChar(191)
  languageCode String   @db.VarChar(16)
  value        String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  language     Language @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  @@unique([key, languageCode])
  @@index([languageCode])
}

model MediaFile {
  id           String    @id @default(cuid())
  filename     String    @db.Text
  originalName String    @db.Text
  mimeType     String    @db.Text
  size         Int
  url          String    @db.Text
  wasabiUrl    String?   @db.Text
  wasabiKey    String?   @db.Text
  isSynced     Boolean   @default(false)
  syncedAt     DateTime?
  altText      String?   @db.Text
  folder       String    @default("general")
  width        Int?
  height       Int?
  originalSize Int?

  // Variant: thumbnail (400px)
  thumbnailUrl  String?
  thumbnailKey  String?
  thumbnailSize Int?

  // Variant: medium (800px)
  mediumUrl  String?
  mediumKey  String?
  mediumSize Int?

  createdAt DateTime @default(now())

  translations MediaFileTranslation[]

  @@index([folder])
  @@index([isSynced])
}

model MediaFileTranslation {
  id           String   @id @default(cuid())
  mediaFileId  String
  languageCode String
  altText      String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  mediaFile MediaFile @relation(fields: [mediaFileId], references: [id], onDelete: Cascade)

  @@unique([mediaFileId, languageCode])
  @@index([languageCode])
}

model PointOfSale {
  id        String   @id @default(cuid())
  name      String
  agentName String?  @db.Text
  type      String
  address   String   @db.Text
  city      String
  country   String
  phone     String?  @db.Text
  email     String?
  website   String?  @db.Text
  imageUrl  String?  @db.Text
  latitude  Float
  longitude Float
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([country])
  @@index([city])
}

model NewsletterSubscriber {
  id             String   @id @default(cuid())
  email          String   @unique
  firstName      String?  @db.Text
  lastName       String?  @db.Text
  company        String?  @db.Text
  phone          String?  @db.Text
  profile        String?  @db.Text
  address        String?  @db.Text
  city           String?  @db.Text
  zip            String?  @db.VarChar(20)
  province       String?  @db.VarChar(10)
  country        String?  @db.Text
  website        String?  @db.Text
  notes          String?  @db.Text
  acceptsPrivacy Boolean  @default(false)
  acceptsUpdates Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
}

model ContactSubmission {
  id            String   @id @default(cuid())
  name          String
  email         String
  subject       String?  @db.Text
  message       String   @db.Text
  company       String?  @db.Text
  phone         String?  @db.Text
  storeId       String?  @db.Text
  contactReason String?  @db.Text
  type          String   @default("general") @db.Text
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?  @db.Text
  userAgent String?  @db.Text
  ipHash    String?  @db.Text
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
  group String @default("general")

  @@index([group])
}

model ContentTypology {
  id           String                       @id @default(cuid())
  contentType  String
  value        String
  label        String
  imageUrl     String?                      @db.Text
  sortOrder    Int                          @default(0)
  isActive     Boolean                      @default(true)
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt
  categories   ContentTypologyCategory[]
  translations ContentTypologyTranslation[]

  @@unique([contentType, value])
  @@index([contentType])
}

model ContentCategory {
  id            String                       @id @default(cuid())
  contentType   String
  value         String
  label         String
  sortOrder     Int                          @default(0)
  isActive      Boolean                      @default(true)
  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt
  typologies    ContentTypologyCategory[]
  subcategories ContentSubcategory[]
  translations  ContentCategoryTranslation[]

  @@unique([contentType, value])
  @@index([contentType])
}

model ContentTypologyCategory {
  id         String          @id @default(cuid())
  typologyId String
  categoryId String
  typology   ContentTypology @relation(fields: [typologyId], references: [id], onDelete: Cascade)
  category   ContentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([typologyId, categoryId])
}

model ContentSubcategory {
  id           String                          @id @default(cuid())
  categoryId   String
  value        String
  label        String
  sortOrder    Int                             @default(0)
  isActive     Boolean                         @default(true)
  createdAt    DateTime                        @default(now())
  updatedAt    DateTime                        @updatedAt
  category     ContentCategory                 @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  translations ContentSubcategoryTranslation[]

  @@index([categoryId])
}

model DimensionBlock {
  id        String   @id @default(cuid())
  name      String
  labels    String   @db.Text
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Catalog {
  id           String               @id @default(cuid())
  name         String
  slug         String               @unique
  section      String               @default("")
  pretitle     String?              @db.Text
  title        String?              @db.Text
  description  String?              @db.Text
  imageUrl     String               @default("") @db.Text
  pdfUrl       String               @default("") @db.Text
  linkText     String?              @db.Text
  isActive     Boolean              @default(true)
  sortOrder    Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  translations CatalogTranslation[]

  @@index([slug])
  @@index([section])
}

model PageImage {
  id        String   @id @default(cuid())
  page      String
  section   String
  label     String
  imageUrl  String
  altText   String?
  linkUrl   String?  @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([page, section])
  @@index([page])
}

model FormConfig {
  id        String   @id @default(cuid())
  formType  String   @unique
  fields    String   @db.Text
  updatedAt DateTime @updatedAt

  translations FormConfigTranslation[]

  @@index([formType])
}

model FormConfigTranslation {
  id           String   @id @default(cuid())
  formConfigId String
  languageCode String
  fields       String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  formConfig FormConfig @relation(fields: [formConfigId], references: [id], onDelete: Cascade)

  @@unique([formConfigId, languageCode])
  @@index([languageCode])
}

model LandingPageConfig {
  id                  String              @id @default(cuid())
  slug                String              @unique @default("default")
  name                String              @default("Landing Page") @db.Text
  permalink           String              @unique @default("evento")
  type                String              @default("evento") // evento, promo, custom
  bannerImage         String?             @db.Text
  logoImage           String?             @db.Text
  heroTitle           String              @default("Milan Design Week 2026") @db.Text
  heroSubtitle        String?             @db.Text
  heroLocation        String?             @db.Text
  heroDescription     String?             @db.Text
  successTitle        String              @default("Thank you. Your QR code has been generated.") @db.Text
  successMessage      String?             @db.Text
  privacyLabel        String              @default("I have read and understood the Privacy Policy on processing of my personal data and I confirm that I am over 18.") @db.Text
  marketingLabel      String?             @db.Text
  buttonLabel         String              @default("Register")
  emailSubject        String?             @db.Text
  emailTitle          String?             @db.Text
  emailBody           String?             @db.Text
  emailFooter         String?             @db.Text
  emailTemplateId     String? // FK to EmailTemplate
  signatureTemplateId String? // FK to SignatureTemplate
  signatureUserData   String?             @db.Text // JSON: {fullName, department, infoLine1, infoLine2, address, phone, mobile}
  formFields          String?             @db.Text // JSON: field layout config [{key, label, width, enabled, order}]
  tagSlug             String?             @db.VarChar(100) // Tag slug to assign on registration
  isActive            Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  registrations       EventRegistration[]
  invitations         EventInvitation[]
  scanUsers           AdminUser[]
}

model EventRegistration {
  id               String             @id @default(cuid())
  uuid             String             @unique @default(cuid())
  landingPageId    String?
  landingPage      LandingPageConfig? @relation(fields: [landingPageId], references: [id])
  firstName        String
  lastName         String
  email            String
  profile          String?
  company          String?
  phone            String?
  country          String
  state            String?
  city             String
  zipCode          String
  privacyAccepted  Boolean            @default(false)
  marketingConsent Boolean            @default(false)
  qrCode           String             @unique
  checkedIn        Boolean            @default(false)
  checkedInAt      DateTime?
  source           String?            @db.VarChar(20) // "invite" | "direct"
  createdAt        DateTime           @default(now())
  invitation       EventInvitation?

  @@index([email])
  @@index([qrCode])
  @@index([createdAt])
  @@index([landingPageId])
}

model EventInvitation {
  id             String             @id @default(cuid())
  email          String
  landingPageId  String?
  landingPage    LandingPageConfig? @relation(fields: [landingPageId], references: [id])
  token          String             @unique
  campaign       String?            @db.Text
  sentAt         DateTime           @default(now())
  openedAt       DateTime?
  clickedAt      DateTime?
  registeredAt   DateTime?
  registrationId String?            @unique
  registration   EventRegistration? @relation(fields: [registrationId], references: [id])
  createdAt      DateTime           @default(now())

  @@index([email])
  @@index([landingPageId])
  @@index([token])
  @@index([sentAt])
}

// ─── Tag System ─────────────────────────────────────────────────────────

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  slug      String       @unique
  color     String       @default("#6b7280")
  createdAt DateTime     @default(now())
  contacts  ContactTag[]
}

model ContactTag {
  id        String   @id @default(cuid())
  email     String
  tagId     String
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([email, tagId])
  @@index([email])
  @@index([tagId])
}

// ─── Email Templates ────────────────────────────────────────────────────

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String
  subject     String   @db.Text
  blocks      String   @db.MediumText
  previewHtml String?  @db.MediumText
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Store: Geography ──────────────────────────────────────────────────

model Region {
  code      String           @id @db.VarChar(8)
  name      String           @db.VarChar(64)
  sortOrder Int              @default(0)
  provinces Province[]
  tariffs   ShippingTariff[]

  @@index([sortOrder])
}

model Province {
  code       String           @id @db.VarChar(8)
  name       String           @db.VarChar(64)
  regionCode String           @db.VarChar(8)
  sortOrder  Int              @default(0)
  region     Region           @relation(fields: [regionCode], references: [code], onDelete: Restrict)
  cities     City[]
  tariffs    ShippingTariff[]

  @@index([regionCode])
  @@index([sortOrder])
}

model City {
  code         String           @id @default(cuid())
  name         String           @db.VarChar(128)
  provinceCode String           @db.VarChar(8)
  createdAt    DateTime         @default(now())
  province     Province         @relation(fields: [provinceCode], references: [code], onDelete: Restrict)
  tariffs      ShippingTariff[]

  @@unique([provinceCode, name])
  @@index([provinceCode])
}

// ─── Store: Shipping ───────────────────────────────────────────────────

enum ShippingService {
  CURBSIDE
  FLOOR_1_3
  FLOOR_4_10_MAX6
}

enum ShippingClass {
  STANDARD
  FRAGILE
  OVERSIZED
  QUOTE_ONLY
}

model ShippingTariff {
  id              String          @id @default(cuid())
  countryCode     String          @db.VarChar(2)
  regionCode      String?         @db.VarChar(8)
  provinceCode    String?         @db.VarChar(8)
  cityCode        String?
  service         ShippingService
  pricePerM3Cents Int
  minChargeCents  Int             @default(0)
  maxVolumeM3     Decimal?        @db.Decimal(7, 3)
  isActive        Boolean         @default(true)
  notes           String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  region   Region?   @relation(fields: [regionCode], references: [code], onDelete: SetNull)
  province Province? @relation(fields: [provinceCode], references: [code], onDelete: SetNull)
  city     City?     @relation(fields: [cityCode], references: [code], onDelete: SetNull)

  @@index([countryCode, regionCode, provinceCode, cityCode])
  @@index([service])
  @@index([cityCode])
  @@index([provinceCode])
  @@index([regionCode])
}

// ─── Store: Attributes (material, finish, color) ───────────────────────

enum StoreAttributeType {
  MATERIAL
  FINISH
  COLOR
  OTHER
}

model StoreAttributeValue {
  id        String             @id @default(cuid())
  type      StoreAttributeType
  code      String             @unique @db.VarChar(64)
  hexColor  String?            @db.VarChar(9)
  sortOrder Int                @default(0)
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  translations StoreAttributeValueTranslation[]
  variantAttrs StoreProductVariantAttribute[]

  @@index([type])
}

model StoreAttributeValueTranslation {
  id           String   @id @default(cuid())
  valueId      String
  languageCode String   @db.VarChar(16)
  label        String   @db.VarChar(128)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  value    StoreAttributeValue @relation(fields: [valueId], references: [id], onDelete: Cascade)
  language Language            @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  @@unique([valueId, languageCode])
  @@index([languageCode])
}

// ─── Store: Categories ─────────────────────────────────────────────────

model StoreCategory {
  id          String   @id @default(cuid())
  parentId    String?
  slug        String   @unique @db.VarChar(191)
  coverImage  String?  @db.Text
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent       StoreCategory?             @relation("StoreCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     StoreCategory[]            @relation("StoreCategoryTree")
  translations StoreCategoryTranslation[]
  products     StoreProduct[]

  @@index([parentId])
  @@index([isPublished])
  @@index([sortOrder])
}

model StoreCategoryTranslation {
  id             String   @id @default(cuid())
  categoryId     String
  languageCode   String   @db.VarChar(16)
  name           String   @db.VarChar(191)
  slug           String   @db.VarChar(191)
  description    String?  @db.Text
  seoTitle       String?  @db.Text
  seoDescription String?  @db.Text
  seoKeywords    String?  @db.Text
  status         String   @default("draft") @db.VarChar(16)
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category StoreCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  language Language      @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  @@unique([categoryId, languageCode])
  @@unique([languageCode, slug])
  @@index([languageCode])
}

// ─── Store: Products & Variants ────────────────────────────────────────

model StoreProduct {
  id                    String    @id @default(cuid())
  productId             String    @unique
  storeCategoryId       String?
  coverImage            String?   @db.Text
  galleryImages         String?   @db.Text
  excludedCatalogImages String?   @db.Text
  isPublished           Boolean   @default(false)
  publishedAt           DateTime?
  sortOrder             Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  product       Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)
  storeCategory StoreCategory?            @relation(fields: [storeCategoryId], references: [id], onDelete: SetNull)
  translations  StoreProductTranslation[]
  variants      StoreProductVariant[]
  favorites     CustomerFavorite[]

  @@index([storeCategoryId])
  @@index([isPublished])
  @@index([sortOrder])
}

model StoreProductTranslation {
  id                   String   @id @default(cuid())
  storeProductId       String
  languageCode         String   @db.VarChar(16)
  name                 String?  @db.VarChar(191)
  slug                 String   @db.VarChar(191)
  shortDescription     String?  @db.Text
  marketingDescription String?  @db.Text
  seoTitle             String?  @db.Text
  seoDescription       String?  @db.Text
  seoKeywords          String?  @db.Text
  status               String   @default("draft") @db.VarChar(16)
  isPublished          Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  storeProduct StoreProduct @relation(fields: [storeProductId], references: [id], onDelete: Cascade)
  language     Language     @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  @@unique([storeProductId, languageCode])
  @@unique([languageCode, slug])
  @@index([languageCode])
}

model StoreProductVariant {
  id               String        @id @default(cuid())
  storeProductId   String
  sku              String        @unique @db.VarChar(64)
  priceCents       Int
  stockQty         Int?
  trackStock       Boolean       @default(false)
  volumeM3         Decimal       @default(0) @db.Decimal(7, 3)
  weightKg         Decimal?      @db.Decimal(8, 2)
  shippingClass    ShippingClass @default(STANDARD)
  coverImage       String?       @db.Text
  galleryImages    String?       @db.Text
  isDefault        Boolean       @default(false)
  isPublished      Boolean       @default(false)
  sortOrder        Int           @default(0)
  // Dimensioni per-variante: riusa i DimensionBlock del catalogo principale
  dimensionBlockId String?       @db.VarChar(191)
  dimensionValues  String?       @db.Text
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  storeProduct StoreProduct                     @relation(fields: [storeProductId], references: [id], onDelete: Cascade)
  attributes   StoreProductVariantAttribute[]
  translations StoreProductVariantTranslation[]
  orderItems   OrderItem[]

  @@index([storeProductId])
  @@index([isPublished])
  @@index([sortOrder])
}

model StoreProductVariantTranslation {
  id           String   @id @default(cuid())
  variantId    String
  languageCode String   @db.VarChar(16)
  name         String?  @db.VarChar(191)
  description  String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  variant  StoreProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  language Language            @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  @@unique([variantId, languageCode])
  @@index([languageCode])
}

model StoreProductVariantAttribute {
  variantId String
  valueId   String

  variant StoreProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  value   StoreAttributeValue @relation(fields: [valueId], references: [id], onDelete: Cascade)

  @@id([variantId, valueId])
  @@index([valueId])
}

// ─── Store: Customers, Addresses, Orders ───────────────────────────────

enum AddressType {
  SHIPPING
  BILLING
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

model Customer {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String?   @db.Text
  firstName      String?   @db.VarChar(128)
  lastName       String?   @db.VarChar(128)
  phone          String?   @db.VarChar(32)
  taxCode        String?   @db.VarChar(32)
  vatNumber      String?   @db.VarChar(32)
  sdiCode        String?   @db.VarChar(16)
  sdiPec         String?   @db.VarChar(191)
  language       String    @default("it") @db.VarChar(16)
  marketingOptIn Boolean   @default(false)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastLoginAt    DateTime?

  addresses Address[]
  orders    Order[]
  favorites CustomerFavorite[]

  @@index([createdAt])
}

model CustomerFavorite {
  id             String   @id @default(cuid())
  customerId     String
  storeProductId String
  createdAt      DateTime @default(now())

  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  storeProduct StoreProduct @relation(fields: [storeProductId], references: [id], onDelete: Cascade)

  @@unique([customerId, storeProductId])
  @@index([customerId])
  @@index([storeProductId])
}

model Address {
  id           String      @id @default(cuid())
  customerId   String
  type         AddressType
  firstName    String      @db.VarChar(128)
  lastName     String      @db.VarChar(128)
  company      String?     @db.VarChar(191)
  street1      String      @db.VarChar(191)
  street2      String?     @db.VarChar(191)
  city         String      @db.VarChar(128)
  zip          String      @db.VarChar(16)
  provinceCode String?     @db.VarChar(8)
  regionCode   String?     @db.VarChar(8)
  countryCode  String      @db.VarChar(2)
  phone        String?     @db.VarChar(32)
  isDefault    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([type])
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique @db.VarChar(32)
  customerId  String?
  status      OrderStatus @default(PENDING)

  email     String  @db.VarChar(191)
  firstName String  @db.VarChar(128)
  lastName  String  @db.VarChar(128)
  phone     String? @db.VarChar(32)
  language  String  @default("it") @db.VarChar(16)

  // Snapshot indirizzi (JSON) — mantiene storicità anche se Address viene modificato
  shippingAddress String @db.Text
  billingAddress  String @db.Text

  // Totali IVA esclusa / IVA / totale
  subtotalCents Int
  shippingCents Int    @default(0)
  taxCents      Int    @default(0)
  totalCents    Int
  currency      String @default("EUR") @db.VarChar(3)
  taxRateBp     Int    @default(2200) // basis points (22% = 2200)

  // Spedizione scelta
  shippingService   ShippingService?
  shippingZoneLabel String?          @db.VarChar(191)
  trackingNumber    String?          @db.VarChar(128)
  trackingCarrier   String?          @db.VarChar(64)
  trackingUrl       String?          @db.Text
  shippedAt         DateTime?
  deliveredAt       DateTime?

  // Pagamento
  paymentProvider       String?   @db.VarChar(32)
  stripeSessionId       String?   @unique @db.VarChar(191)
  stripePaymentIntentId String?   @unique @db.VarChar(191)
  paidAt                DateTime?

  // Rimborso
  refundedAt        DateTime?
  refundAmountCents Int?
  refundReason      String?   @db.Text
  stripeRefundId    String?   @db.VarChar(191)

  // Note
  customerNotes String? @db.Text
  adminNotes    String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    OrderItem[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([email])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  variantId String?

  // Snapshot al momento dell'ordine (per storicità)
  productName    String   @db.VarChar(191)
  variantName    String?  @db.VarChar(191)
  sku            String   @db.VarChar(64)
  unitPriceCents Int
  quantity       Int
  volumeM3       Decimal  @db.Decimal(7, 3)
  weightKg       Decimal? @db.Decimal(8, 2)
  totalCents     Int

  // Attributi snapshot (JSON: {material:"Noce", finish:"Satinato", color:"Rosso"})
  attributesSnapshot String? @db.Text

  createdAt DateTime @default(now())

  order   Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant StoreProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([variantId])
}
